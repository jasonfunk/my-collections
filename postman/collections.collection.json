            },
            "url": {
              "raw": "{{baseUrl}}/collections/transformers/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "transformers",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            }
          }
        },
        {
          "name": "Delete transformer",
          "request": {
            "method": "DELETE",
