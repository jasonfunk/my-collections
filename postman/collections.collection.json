{
  "info": {
    "name": "Collections API",
    "_postman_id": "collections-api-v1",
    "description": "CRUD endpoints for Star Wars figures, G1 Transformers, and Masters of the Universe figures. All endpoints require a Bearer token \u2014 obtain one via the Auth collection first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Stats",
      "item": [
        {
          "name": "GET /collections/stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/collections/stats",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "stats"
              ]
            },
            "description": "Returns owned/wishlist counts and estimated total values across all collection types."
          }
        }
      ]
    },
    {
      "name": "Recent",
      "item": [
        {
          "name": "GET /collections/recent",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/collections/recent?limit=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "recent"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "5",
                  "description": "Max items to return (default 5, max 20)"
                }
              ]
            },
            "description": "Returns the most recently added user items across all collection types, sorted by creation date descending."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Star Wars",
      "item": [
        {
          "name": "Browse catalog",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/catalog",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "catalog"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "BASIC_FIGURE",
                  "disabled": true
                },
                {
                  "key": "line",
                  "value": "STAR_WARS",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": true
                }
              ]
            },
            "description": "Paginated catalog of what Kenner made. Filter by category (BASIC_FIGURE, VEHICLE, PLAYSET, etc.) and/or line."
          }
        },
        {
          "name": "Get catalog item by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/catalog/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "catalog",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            },
            "description": "Single catalog item with full detail (accessories, image URL, variant info, etc.)"
          }
        },
        {
          "name": "List my items",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "items"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": true
                }
              ]
            },
            "description": "The authenticated user's personal records \u2014 both owned items and wishlist. Each record includes the embedded catalog item."
          }
        },
        {
          "name": "Claim catalog item (owned)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"catalogId\": \"<uuid-from-catalog>\",\n  \"isOwned\": true,\n  \"condition\": \"C9\",\n  \"packagingCondition\": \"NONE\",\n  \"isComplete\": false,\n  \"ownedAccessories\": [\"Lightsaber\"],\n  \"isCarded\": false,\n  \"acquisitionSource\": \"EBAY\",\n  \"acquisitionDate\": \"2024-03-15\",\n  \"acquisitionPrice\": 45.00,\n  \"estimatedValue\": 60.00,\n  \"notes\": \"Slight discoloration on helmet\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "items"
              ]
            },
            "description": "Create a personal record for a catalog item. 409 if a record already exists for this catalogId."
          }
        },
        {
          "name": "Add to wishlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"catalogId\": \"<uuid-from-catalog>\",\n  \"isOwned\": false,\n  \"wishlistPriority\": \"HIGH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "items"
              ]
            }
          }
        },
        {
          "name": "Update my item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition\": \"C8\",\n  \"estimatedValue\": 55.00,\n  \"ownedAccessories\": [\"Lightsaber\", \"Belt\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/items/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "items",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            },
            "description": "Update personal record fields. catalogId cannot be changed."
          }
        },
        {
          "name": "Delete my item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/items/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "items",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            },
            "description": "Remove personal record. The catalog item is not affected."
          }
        },
        {
          "name": "Get wishlist",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/wishlist",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "wishlist"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": true
                }
              ]
            },
            "description": "Paginated wishlist items (isOwned=false), sorted HIGH priority first then catalog name."
          }
        },
        {
          "name": "Mark as acquired",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition\": \"C8\",\n  \"acquisitionSource\": \"EBAY\",\n  \"acquisitionDate\": \"2025-04-08\",\n  \"acquisitionPrice\": 45.0,\n  \"estimatedValue\": 60.0,\n  \"notes\": \"Picked up at a great price\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/collections/star-wars/items/:id/acquired",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "collections",
                "star-wars",
                "items",
                ":id",
                "acquired"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            },
            "description": "Sets isOwned=true, nulls wishlistPriority. All body fields are optional."
          }
        }
      ]
    },
    {
      "name": "Transformers",
      "item": [
