# =============================================================================
# my-collections Web App — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in values for your environment.
# Vite exposes only variables prefixed with VITE_ to browser code.
# Never put secrets here — these values are bundled into the JS output.
#
# =============================================================================

# -----------------------------------------------------------------------------
# API base URL
# -----------------------------------------------------------------------------
#
# Origin of the NestJS API server.
# Leave EMPTY in development — the Vite dev server proxy forwards /api/*
# to localhost:3000 automatically (see vite.config.ts).
#
# In production, set this to the full API origin (no trailing slash):
#   VITE_API_BASE_URL=https://api.example.com
#
VITE_API_BASE_URL=
