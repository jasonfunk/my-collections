# =============================================================================
# my-collections API — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in all values marked <REQUIRED>.
# Never commit .env to version control.
#
# Generate strong random secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# or:
#   openssl rand -hex 32
#
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the NestJS app listens on.
PORT=3000

# Runtime environment. Controls logging verbosity, Swagger availability,
# and migration behaviour. Must be "production" in prod.
# Values: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string.
# Dev default matches docker-compose.yml credentials.
# Production: use a strong password and a non-default database user.
DATABASE_URL=postgresql://my_collections:my_collections_dev@localhost:5432/my_collections

# -----------------------------------------------------------------------------
# JWT — Access Token
# -----------------------------------------------------------------------------
#
# REQUIRED in production. Must be at least 32 random hex characters.
# Use a DIFFERENT secret for access vs. refresh tokens so that a leaked
# access secret cannot be used to forge long-lived refresh tokens.
#
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_ACCESS_SECRET=<GENERATE: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# How long access tokens are valid. Short-lived by design.
# Format: ms-compatible string — e.g. 15m, 1h, 2d
JWT_ACCESS_EXPIRES_IN=15m

# -----------------------------------------------------------------------------
# JWT — Refresh Token
# -----------------------------------------------------------------------------
#
# REQUIRED in production. Must be a DIFFERENT secret from JWT_ACCESS_SECRET.
#
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

JWT_REFRESH_SECRET=<GENERATE: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# How long refresh tokens are valid. Longer-lived — rotate periodically.
# Format: number followed by d (days) — e.g. 7d, 30d, 90d
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Cookie Security
# -----------------------------------------------------------------------------
#
# Secret used to sign the httpOnly refresh-token cookie.
# REQUIRED in production. Must be at least 32 random hex characters.
# Generate the same way as the JWT secrets above.

COOKIE_SECRET=<GENERATE: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
#
# Comma-separated list of allowed origins for the API.
# In development this is the Vite dev server.
# In production this is your deployed frontend URL.
# Example: https://collections.example.com,https://www.collections.example.com

ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Registration
# -----------------------------------------------------------------------------

# Set to "true" to allow new user registrations.
# Set to "false" to lock down the /auth/register endpoint (recommended in prod
# once your account is created).
REGISTRATION_ENABLED=true
