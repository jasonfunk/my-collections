PORT=3000
DATABASE_URL=postgresql://my_collections:my_collections_dev@localhost:5432/my_collections

# JWT — use separate secrets so a compromised access secret can't forge refresh tokens
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production-too
JWT_REFRESH_EXPIRES_IN=30d

# Set to "true" to allow new registrations. Set to "false" to lock down registration.
REGISTRATION_ENABLED=true
